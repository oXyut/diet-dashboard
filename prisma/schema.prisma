// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "cockroachdb"
  url      = env("DATABASE_URL")
}

model HealthData {
  id                String   @id @default(uuid()) @db.Uuid
  date              DateTime @unique @db.Date
  weight            Decimal? @db.Decimal(5, 2)
  bodyFatPercentage Decimal? @map("body_fat_percentage") @db.Decimal(4, 2)
  muscleMass        Decimal? @map("muscle_mass") @db.Decimal(5, 2)
  steps             Int?
  activeCalories    Int?     @map("active_calories")
  restingCalories   Int?     @map("resting_calories")
  totalCalories     Int?     @map("total_calories")
  dietaryCalories   Int?     @map("dietary_calories")
  // PFC栄養素
  proteinG          Decimal? @map("protein_g") @db.Decimal(6, 2)
  fatG              Decimal? @map("fat_g") @db.Decimal(6, 2)
  carbohydrateG     Decimal? @map("carbohydrate_g") @db.Decimal(6, 2)
  // その他の栄養素
  fiberG            Decimal? @map("fiber_g") @db.Decimal(5, 2)
  sugarG            Decimal? @map("sugar_g") @db.Decimal(5, 2)
  sodiumMg          Decimal? @map("sodium_mg") @db.Decimal(7, 2)
  
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  
  @@map("health_data")
}

model Goal {
  id                      String   @id @default(uuid()) @db.Uuid
  name                    String   @db.String(100)
  description             String?
  targetWeightKg          Decimal? @map("target_weight_kg") @db.Decimal(5, 2)
  startingWeightKg        Decimal? @map("starting_weight_kg") @db.Decimal(5, 2)
  proteinTargetPercent    Decimal? @map("protein_target_percent") @db.Decimal(5, 2)
  fatTargetPercent        Decimal? @map("fat_target_percent") @db.Decimal(5, 2)
  carbohydrateTargetPercent Decimal? @map("carbohydrate_target_percent") @db.Decimal(5, 2)
  startDate               DateTime @map("start_date") @db.Date
  endDate                 DateTime @map("end_date") @db.Date
  dailyCalorieIntakeMin   Int?     @map("daily_calorie_intake_min")
  dailyCalorieIntakeMax   Int?     @map("daily_calorie_intake_max")
  dailyProteinMinG        Decimal? @map("daily_protein_min_g") @db.Decimal(6, 2)
  dailyProteinMaxG        Decimal? @map("daily_protein_max_g") @db.Decimal(6, 2)
  dailyFatMinG            Decimal? @map("daily_fat_min_g") @db.Decimal(6, 2)
  dailyFatMaxG            Decimal? @map("daily_fat_max_g") @db.Decimal(6, 2)
  dailyCarbMinG           Decimal? @map("daily_carb_min_g") @db.Decimal(6, 2)
  dailyCarbMaxG           Decimal? @map("daily_carb_max_g") @db.Decimal(6, 2)
  dailyStepsTarget        Int?     @map("daily_steps_target")
  isActive                Boolean  @default(true) @map("is_active")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")
  
  @@map("goals")
}

model MobileDevice {
  id          String        @id @default(uuid()) @db.Uuid
  name        String        @db.String(100)
  tokenHash   String        @unique @map("token_hash") @db.String(64)
  createdAt   DateTime      @default(now()) @map("created_at")
  lastUsedAt  DateTime?     @map("last_used_at")
  revokedAt   DateTime?     @map("revoked_at")
  pairingCode PairingCode?

  @@map("mobile_devices")
}

model PairingCode {
  id        String        @id @default(uuid()) @db.Uuid
  codeHash  String        @unique @map("code_hash") @db.String(64)
  expiresAt DateTime      @map("expires_at")
  usedAt    DateTime?     @map("used_at")
  createdAt DateTime      @default(now()) @map("created_at")
  deviceId  String?       @unique @map("device_id") @db.Uuid
  device    MobileDevice? @relation(fields: [deviceId], references: [id])

  @@index([expiresAt])
  @@map("pairing_codes")
}
