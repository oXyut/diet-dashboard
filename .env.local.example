# CockroachDB
DATABASE_URL=postgresql://user:password@host:26257/defaultdb?sslmode=verify-full

# API Security (for write operations)
API_SECRET_KEY=your_custom_api_key_for_iphone

# 端末トークン・ペアリングコードのハッシュ専用値。API_SECRET_KEY とは別のランダム値にする
MOBILE_TOKEN_PEPPER=your_mobile_token_pepper

# ペアリングコード発行 API のベース URL (scripts/create-mobile-pairing-code.js が使用)
MOBILE_API_BASE_URL=https://your-app.vercel.app
